# ────────────────────────────────────────────────────────────
# Shiksha AI Service — Environment Variables
# Copy this to `.env` and fill in your actual keys.
# ────────────────────────────────────────────────────────────

# ── FastAPI ───────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8001
LOG_LEVEL=INFO

# ── Java ERP Backend ─────────────────────────────────────────
ERP_BASE_URL=http://localhost:8080
ERP_API_VERSION=v1
# Same JWT secret used by the Java backend for token validation
JWT_SECRET_KEY=jfhsdafasdfasdf%af6sdf4sdaf654sd65f4sd564sd654fad5f4sa6f5sa4f65af4dsf874f65132f1sd68f5asdfbsa4n56

# ── Redis (Docker container from backend docker-compose) ─────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=3600         # 1 hour session expiry
REDIS_AI_CONFIG_KEY=ai:active_config   # Key storing the chosen model config

# ── AI Model Provider Keys ────────────────────────────────────
# -- Google Gemini --
GOOGLE_API_KEY=your_google_api_key_here

# -- OpenAI (GPT-4o-mini) --
OPENAI_API_KEY=your_openai_api_key_here

# -- Groq --
GROQ_API_KEY=your_groq_api_key_here

# -- OpenRouter --
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Shiksha-Intelligence   # Shown in OpenRouter dashboard

# ── Active Model Config (initial defaults, overridden by Redis) ─
# Possible values: gemini-flash | gpt-4o-mini | groq-llama | groq-mixtral
#                  openrouter-mistral | openrouter-gemma
ACTIVE_MODEL=gemini-flash

# ── Intent Classification (always uses cheapest model) ───────
# Override if you want a different cheap model for classification
INTENT_CLASSIFIER_MODEL=gemini-flash

# ── RAG / ChromaDB (Phase 2) ─────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=school_knowledge
