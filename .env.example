# ────────────────────────────────────────────────────────────
# Shiksha AI Service — Environment Variables
# Copy this to `.env` and fill in your actual keys.
# ────────────────────────────────────────────────────────────

# ── FastAPI ───────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8001
LOG_LEVEL=INFO

# ── Java ERP Backend ─────────────────────────────────────────
ERP_BASE_URL=http://localhost:8080
ERP_API_VERSION=v1
# Same JWT secret used by the Java backend for token validation
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALLOW_MOCK=True

# ── Redis (Docker container from backend docker-compose) ─────
REDIS_URL=redis://localhost:6379
REDIS_SESSION_TTL_SECONDS=3600         # 1 hour session expiry
REDIS_AI_CONFIG_KEY=ai:active_config   # Key storing the chosen model config

# ── AI Model Provider Keys ────────────────────────────────────
# -- Google Gemini --
GOOGLE_API_KEY=your_google_api_key_here

# -- OpenAI (GPT-4o-mini) --
OPENAI_API_KEY=your_openai_api_key_here

# -- Groq --
GROQ_API_KEY=your_groq_api_key_here

# -- OpenRouter --
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Shiksha-Intelligence   # Shown in OpenRouter dashboard

# ── Active Model Config (initial defaults, overridden by Redis) ─
# Possible values: gemini-flash | gpt-4o-mini | groq-llama | groq-mixtral
#                  openrouter-mistral | openrouter-gemma
ACTIVE_MODEL=gemini-3-flash
INTENT_CLASSIFIER_MODEL=gemini-3-flash

# ── RAG — Pinecone (Phase 2) ──────────────────────────────────
# Get free API key at: https://pinecone.io
# Free plan: 2GB storage, 5 indexes, 100 namespaces — sufficient for 1 school
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=shiksha-knowledge
PINECONE_ENVIRONMENT=us-east-1-aws
RAG_TOP_K=5

# Set to True to use Pinecone, False to use local ChromaDB (dev/testing)
USE_PINECONE=False

# ── RAG — ChromaDB (local dev fallback) ──────────────────────
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=school_knowledge

# ── Long-term Student Memory (Optional — Supabase PostgreSQL) ─
# Enable this to persist student preferences (language, weak subjects, etc.)
# across sessions. Safe to leave empty — system works without it.
ENABLE_LONG_TERM_MEMORY=False
DATABASE_URL=                          # e.g. postgresql+asyncpg://user:pass@host:5432/db

# ── CORS (Production) ─────────────────────────────────────────────────────
# Comma-separated list of additional frontend origins to allow.
# localhost:3000/3001/5173 are always included.
# Example: EXTRA_CORS_ORIGINS=https://app.shiksha.school,https://admin.shiksha.school
EXTRA_CORS_ORIGINS=
